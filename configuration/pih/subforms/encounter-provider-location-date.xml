<!--
    This encapsulates the standard logic for capturing the provider, date, and location of an encounter
    The following sections can be overridden from the default configurations that are shown:

    <label subform-parameter="encounter-provider-label"><uimessage code="emr.patientDashBoard.providerRequired"/></label>

    <span subform-parameter="encounter-provider-widget">
        <encounterProviderAndRole default="currentUser" encounterRole="4f10ad1a-ec49-48df-98c7-1391c6ac7f05" required="true"/>
    </span>

    <label subform-parameter="encounter-location-label"><uimessage code="emr.locationRequired"/></label>

    <span subform-parameter="encounter-location-widget">
        <encounterLocation default="SessionAttribute:emrContext.sessionLocationId" tags="Consult Note Location"/>
    </span>

    <label subform-parameter="encounter-date-label"><uimessage code="emr.patientDashBoard.date"/></label>

    <span subform-parameter="encounter-date-widget">
        <encounterDate id="encounterDate" default="now" />
    </span>
-->
<div>
    <ifMode mode="VIEW" include="false">

        <!-- the "color" on "#who select" is to override the base style in UI-Commons that greys out the text when the widget is disabled -->
        <style type="text/css">
            #who-when-where {
                margin-bottom: 6px;
                border-bottom: 1px solid #ccc;
            }
            #who-when-where p {
                display: inline-block;
                padding-right: 20px;
            }
            #who select {
                color: #003f5e !important;
            }
            #where > input[type=text] {
                display: inline-block;
            }
            .field-error {
                color: #ff6666;
                font-size: 1.1em;
                display: block;
            }
        </style>

        <!-- users without either of these privileges aren't allowed to change encounter date -->
        <includeIf velocityTest="!$user.hasPrivilege('Task: emr.retroConsultNoteThisProviderOnly') and !($user.hasPrivilege('Task: emr.retroConsultNote'))">
            <script type="text/javascript">
                jQuery(function() {
                    getField('encounterDate.value').prop('disabled', true);
                });
            </script>
        </includeIf>

        <!-- users without this privilege are only able to enter notes in their own name -->
        <includeIf velocityTest="!$user.hasPrivilege('Task: emr.retroConsultNote')">
            <script type="text/javascript">
                <!-- since there can be multiple encounterProviderAndRole tags on a form HFE provides no direct way to reference it -->
                jQuery(function() {
                    jq('#who').find('select').first().prop('disabled', true);
                });
            </script>
        </includeIf>

        <div id="who-when-where">
            <p id="who">
                <label subform-parameter="encounter-provider-label"><uimessage code="emr.patientDashBoard.providerRequired"/></label>
                <span subform-parameter="encounter-provider-widget">
                    <encounterProviderAndRole id="encounterProvider" default="currentUser" encounterRole="4f10ad1a-ec49-48df-98c7-1391c6ac7f05" required="true"/>
                </span>
            </p>
            <p id="where">
                <label subform-parameter="encounter-location-label"><uimessage code="emr.locationRequired"/></label>
                <span subform-parameter="encounter-location-widget">
                    <encounterLocation default="SessionAttribute:emrContext.sessionLocationId" tags="Consult Note Location"/>
                </span>
            </p>
            <p id="when">
                <label subform-parameter="encounter-date-label"><uimessage code="emr.patientDashBoard.date"/></label>
                <span subform-parameter="encounter-date-widget">
                    <encounterDate id="encounterDate" default="now" />
                </span>
            </p>
        </div>

    </ifMode>
</div>