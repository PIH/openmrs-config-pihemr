<div>
    <postSubmissionAction class="org.openmrs.module.pihcore.htmlformentry.action.ScheduleAppointmentAction"/>

    <h3>Schedule Appointment</h3>
    <p class="side-by-side">
        <ifMode mode="ENTER" include="false">
            <strong><uimessage code="pihcore.appointment.viewEditMessage"/></strong>
        </ifMode>

        <label><uimessage code="pihcore.appointment.schedule"/></label>
	<span>
            <obs id="schedule-appointment" conceptId="PIH:Schedule appointment" style="radio" answerConceptIds="PIH:YES,PIH:NO" required="true">
                <controls>
                    <when value="PIH:YES" thenDisplay="#schedule-appointment-fields"/>
                </controls>
            </obs>
        </span>
    </p>

    <ifMode mode="EDIT" include="true">
        <span id="appointment-edit-mode" style="display:none"/>
    </ifMode>

    <subform path="configuration/pih/subforms/schedule-appointment.js"/>

    <div id="schedule-appointment-fields">
    <obsgroup groupingConceptId="PIH:Scheduled visit construct" showIfEmpty="false"
              hiddenConceptId="PIH:Visit type" hiddenAnswerConceptId="PIH:SCHEDULED VISIT">

        <div id="appointment-datetime-field">
            <label><uimessage code="pihcore.appointment.dateTime"/></label>
            <p class="date-one-line">
                <obs conceptId="PIH:Return visit datetime" allowFutureDates="true" allowPastDates="false" showTime="true"/>
	    </p>
        </div>

        <div id="appointment-location-field">
            <label><uimessage code="pihcore.appointment.location"/></label>
            <obs conceptId="PIH:Location" style="location" answerLocationTags="Appointment Location" defaultValue="SessionAttribute:emrContext.sessionLocationId" />
        </div>

        <div id="appointment-service-field">
            <label><uimessage code="pihcore.appointment.service"/></label>
	    <appointmentServiceObs conceptId="PIH:Appointment service" subform-parameter="appointment-service-obs" />
        </div>

        <div id="appointment-provider-field">
            <label><uimessage code="pihcore.provider"/></label>
            <obs conceptId="PIH:Provider name non-coded" style="provider_autocomplete"/>
        </div>

        <div>
            <label><uimessage code="pihcore.appointment.notes"/></label>
            <obs conceptId="PIH:GENERAL FREE TEXT" style="textarea"/>
        </div>

    </obsgroup>
    </div>

</div>
